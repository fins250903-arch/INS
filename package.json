{
  "name": "ins",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:lan": "astro dev --host 0.0.0.0",
    "build": "npm run wp:resolve-images && astro build",
    "preview": "astro preview",
    "preview:lan": "astro preview --host 0.0.0.0",
    "astro": "astro",
    "wp:import": "tsx scripts/parse-wordpress-xml.ts",
    "wp:cache-images": "node scripts/cache-post-images.cjs",
    "wp:resolve-images": "node scripts/resolve-local-images.cjs",
    "wp:sync": "npm run wp:import && npm run wp:resolve-images",
    "wp:audit:thumbs": "node scripts/export-thumbnail-audit.cjs",
    "blog:migrate": "node scripts/migrate-wp-md-to-content.cjs",
    "blog:validate": "node scripts/validate-blog-content.mjs",
    "blog:fix-media": "node scripts/fix-blog-media-paths.mjs",
    "gsc": "tsx scripts/gsc/sync.ts",
    "gsc:sync": "npm run build && npm run gsc -- sync",
    "sachi:sync": "npm run gsc:sync"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.7",
    "@tailwindcss/postcss": "^4.2.4",
    "astro": "^6.0.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "fast-xml-parser": "^5.8.0",
    "tsx": "^4.22.3"
  }
}
