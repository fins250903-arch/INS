# Decap CMS (GitHub OAuth on Vercel) — https://decapcms.org/docs/github-backend/
# GitHub OAuth App の Authorization callback URL: https://insbs.net/callback
# （旧 URL https://insbs.net/api/decap/callback も引き続き動作します）
DECAP_GITHUB_CLIENT_ID=
DECAP_GITHUB_CLIENT_SECRET=
# 本番ドメイン（プレビュー URL では OAuth が動かない場合があります）
DECAP_SITE_URL=https://insbs.net

# Google サービスアカウント JSON キーへのパス（プロジェクトルートからの相対パス可）
# 例: secrets/gsc-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gsc-service-account.json

# 任意: ログ確認用（JSON 内の client_email と同じ）
# GOOGLE_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
