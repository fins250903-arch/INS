---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
---

<Layout title="お問い合わせありがとうございます｜アイエヌエス車内清掃">
  <Header />
  <main class="bg-white">
    <section class="max-w-3xl mx-auto px-6 py-12 text-center">
      <h1 class="text-3xl font-bold">お問い合わせありがとうございます。</h1>
      <p class="mt-4 text-sm text-gray-600">担当者よりご連絡いたします。しばらくお待ちください。</p>
      <a href="/" class="mt-6 inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-white font-bold">ホーム画面</a>
    </section>
  </main>
  <Footer />
  <FloatingCTA />
</Layout>
