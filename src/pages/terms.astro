---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import { buildPageJsonLd } from '../lib/json-ld-site';

const termsJsonLd = buildPageJsonLd({
  path: '/terms/',
  title: '利用規約｜アイエヌエス車内清掃',
  description: 'サービス利用に関する規約です。'
});
---

<Layout
  title="利用規約｜アイエヌエス車内清掃"
  description="サービス利用に関する規約です。"
  canonical="/terms/"
  jsonLd={termsJsonLd}
>
  <Header />
  <main class="bg-white">
    <section class="max-w-4xl mx-auto px-6 py-12">
      <h1 class="text-3xl font-bold">利用規約</h1>
      <p class="mt-4 text-sm text-gray-600">サービス利用に関する注意事項や免責事項を記載します。</p>
    </section>
  </main>
  <Footer />
  <FloatingCTA />
</Layout>
