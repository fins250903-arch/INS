---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FloatingCTA from '../../../components/FloatingCTA.astro';
import BlogCta from '../../../components/BlogCta.astro';
import { CHIIKI_REGIONS } from '../../../data/blog-chiiki';
import { buildPageJsonLd } from '../../../lib/json-ld-site';
import {
  formatBlogDateLong,
  getAllBlogCategories,
  getBlogPath,
  getPostsForCategory,
  getPublishedBlogPosts,
  getAreaLabel
} from '../../../lib/blog-content';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  const categories = getAllBlogCategories(posts);
  return categories.map((category) => ({
    params: { category },
    props: { category }
  }));
}

interface Props {
  category: string;
}

const { category } = Astro.props;
const filtered = await getPostsForCategory(category);
const chiikiMatch = CHIIKI_REGIONS.find((r) => r.categoryLabel === category);

const formatDate = formatBlogDateLong;
const categoryPath = `/blog/category/${encodeURIComponent(category)}/`;
const categoryJsonLd = buildPageJsonLd({
  path: categoryPath,
  title: `${category}｜ブログ一覧`,
  description: `${category}カテゴリのブログ記事一覧です。`,
  pageType: 'CollectionPage'
});
---

<Layout
  title={`${category}｜ブログ一覧`}
  description={`${category}カテゴリのブログ記事一覧です。`}
  canonical={categoryPath}
  jsonLd={categoryJsonLd}
>
  <Header />
  <main class="bg-white">
    <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-12">
      <nav class="text-sm text-gray-500">
        <a href="/blog/" class="underline hover:text-primary">ブログ一覧</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800">{category}</span>
      </nav>
      <h1 class="mt-4 text-2xl font-bold sm:text-3xl">{category} の記事</h1>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {filtered.map((post) => (
          <a href={getBlogPath(post)} class="block rounded-xl border border-gray-200 p-4 transition hover:shadow">
            <div class="text-xs text-gray-500">{formatDate(post.data.date)}</div>
            <div class="mt-2 font-semibold leading-snug text-gray-900">{post.data.title}</div>
            <div class="mt-2 text-xs text-gray-500">{getAreaLabel(post)}</div>
          </a>
        ))}
      </div>
    </section>

    <BlogCta regionFull={chiikiMatch?.name} regionSlug={chiikiMatch?.slug} />
  </main>
  <Footer regionFull={chiikiMatch?.name} />
  <FloatingCTA />
</Layout>
