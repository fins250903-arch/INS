---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FloatingCTA from '../../../components/FloatingCTA.astro';
import { getCollection } from 'astro:content';
import { CHIIKI_REGIONS } from '../../../data/blog-chiiki';
import { buildPageJsonLd } from '../../../lib/json-ld-site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const categories = Array.from(
    new Set(posts.flatMap((post) => post.data.categories || []))
  );
  return categories.map((category) => ({
    params: { category },
    props: { category }
  }));
}

const { category } = Astro.props;
const posts = await getCollection('blog');
const filtered = posts.filter(
  (post) => (post.data.categories || []).includes(category)
);

const chiikiMatch = CHIIKI_REGIONS.find((r) => r.categoryLabel === category);

const formatDate = (date) => {
  const d = new Date(date);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
};
const categoryPath = `/blog/category/${encodeURIComponent(category)}/`;
const categoryJsonLd = buildPageJsonLd({
  path: categoryPath,
  title: `${category}｜ブログ一覧`,
  description: `${category}カテゴリのブログ記事一覧です。`,
  pageType: 'CollectionPage'
});
---

<Layout
  title={`${category}｜ブログ一覧`}
  description={`${category}カテゴリのブログ記事一覧です。`}
  canonical={categoryPath}
  jsonLd={categoryJsonLd}
>
  <Header />
  <main class="bg-white">
    <section class="max-w-6xl mx-auto px-6 py-12">
      <h1 class="text-3xl font-bold">{category} の記事</h1>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {filtered.map((post) => (
          <a href={`/blog/${post.id}/`} class="block rounded-xl border border-gray-200 p-4 hover:shadow">
            <div class="text-xs text-gray-500">{formatDate(post.data.date)}</div>
            <div class="mt-2 font-semibold text-gray-900">{post.data.title}</div>
            <div class="mt-2 text-xs text-gray-500">{post.data.categories?.join(' / ')}</div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer regionFull={chiikiMatch?.name} />
  <FloatingCTA />
</Layout>
