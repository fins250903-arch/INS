---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FloatingCTA from '../../../components/FloatingCTA.astro';
import posts from '../../../data/wp-posts.json';
import { CHIIKI_REGIONS } from '../../../data/blog-chiiki';

export function getStaticPaths() {
  const categories = Array.from(
    new Set(posts.filter((post) => post.status === 'publish').flatMap((post) => post.categories || []))
  );
  return categories.map((category) => ({
    params: { category },
    props: { category }
  }));
}

const { category } = Astro.props;
const filtered = posts.filter(
  (post) => post.status === 'publish' && (post.categories || []).includes(category)
);

const chiikiMatch = CHIIKI_REGIONS.find((r) => r.categoryLabel === category);

const formatDate = (value) => value.split(' ')[0].replace(/-/g, '.');
---

<Layout title={`${category}｜ブログ一覧`}>
  <Header />
  <main class="bg-white">
    <section class="max-w-6xl mx-auto px-6 py-12">
      <h1 class="text-3xl font-bold">{category} の記事</h1>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {filtered.map((post) => (
          <a href={`/blog/${post.slug}/`} class="block rounded-xl border border-gray-200 p-4 hover:shadow">
            <div class="text-xs text-gray-500">{formatDate(post.date)}</div>
            <div class="mt-2 font-semibold text-gray-900">{post.title}</div>
            <div class="mt-2 text-xs text-gray-500">{post.categories?.join(' / ')}</div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer regionFull={chiikiMatch?.name} />
  <FloatingCTA />
</Layout>
