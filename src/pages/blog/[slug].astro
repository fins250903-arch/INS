---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import { getCollection } from 'astro:content';
import { CHIIKI_REGIONS } from '../../data/blog-chiiki';
import { buildBlogPostJsonLd } from '../../lib/blog-json-ld';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.status === 'publish');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (value: string) => value.replace(/-/g, '.');

let footerRegionFull: string | undefined;
for (const c of post.data.categories || []) {
  const m = CHIIKI_REGIONS.find((r) => r.categoryLabel === c);
  if (m) {
    footerRegionFull = m.name;
    break;
  }
}

const blogJsonLd = buildBlogPostJsonLd({
  slug: post.slug,
  title: post.data.title,
  description: post.data.description || post.data.title,
  datePublished: post.data.date
});
---

<Layout
  title={`${post.data.title}｜アイエヌエス車内清掃`}
  description={post.data.description || post.data.title}
  canonical={`/blog/${post.slug}/`}
  jsonLd={blogJsonLd}
>
  <Header />
  <main class="bg-white">
    <article class="max-w-3xl mx-auto px-6 py-12">
      <p class="text-xs text-gray-500">{formatDate(post.data.date)}</p>
      <h1 class="mt-2 text-3xl font-bold">{post.data.title}</h1>
      <div class="mt-4 text-xs text-gray-500">{post.data.categories?.join(' / ')}</div>
      <div class="mt-8 prose max-w-none">
        <Content />
      </div>
    </article>
  </main>
  <Footer regionFull={footerRegionFull} />
  <FloatingCTA />
</Layout>
