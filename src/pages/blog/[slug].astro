---
import { findPostsBySlug, getBlogPath } from '../../lib/blog-content';

export async function getStaticPaths() {
  const { getPublishedBlogPosts, getBlogSlug } = await import('../../lib/blog-content');
  const posts = await getPublishedBlogPosts();
  const slugs = Array.from(new Set(posts.map((post) => getBlogSlug(post))));

  return slugs.map((slug) => ({
    params: { slug },
    props: { slug }
  }));
}

const { slug } = Astro.props;
const matches = await findPostsBySlug(slug);

if (matches.length === 0) {
  return Astro.redirect('/blog/');
}

/** 旧 URL `/blog/{slug}/` は福岡（メインサイト）を優先してリダイレクト */
const preferred =
  matches.find((post) => post.data.region === 'fukuoka') ||
  matches.sort((a, b) => a.data.region.localeCompare(b.data.region))[0];

return Astro.redirect(encodeURI(getBlogPath(preferred)));
