---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import posts from '../../data/wp-posts.json';
import { CHIIKI_REGIONS } from '../../data/blog-chiiki';
import { buildBlogPostJsonLd } from '../../lib/blog-json-ld';

export function getStaticPaths() {
  return posts
    .filter((post) => post.status === 'publish')
    .map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const formatDate = (dateStr: string) => {
  try {
    const date = new Date(dateStr);
    const year = date.getFullYear();
    const month = date.getMonth() + 1;
    const day = date.getDate();
    return `${year}年${month}月${day}日`;
  } catch {
    return dateStr;
  }
};

let footerRegionFull: string | undefined;
for (const c of post.categories || []) {
  const m = CHIIKI_REGIONS.find((r) => r.categoryLabel === c);
  if (m) {
    footerRegionFull = m.name;
    break;
  }
}

const blogJsonLd = buildBlogPostJsonLd({
  slug: post.slug,
  title: post.title,
  description: post.title,
  datePublished: post.date
});
---

<Layout
  title={`${post.title}｜アイエヌエス車内清掃`}
  description={post.title}
  canonical={`/blog/${post.slug}/`}
  jsonLd={blogJsonLd}
>
  <Header />
  <main class="bg-white">
    <article class="max-w-3xl mx-auto px-6 py-12">
      {post.featured_image && (
        <img
          src={post.featured_image}
          alt={post.title}
          class="w-full h-auto rounded-lg mb-8"
          loading="lazy"
          decoding="async"
          referrerpolicy="no-referrer"
        />
      )}
      <p class="text-xs text-gray-500">{formatDate(post.date)}</p>
      <h1 class="mt-2 text-3xl font-bold">{post.title}</h1>
      <div class="mt-4 text-xs text-gray-500">{post.categories?.join(' / ')}</div>
      <div class="mt-8 prose max-w-none wp-content" set:html={post.content}></div>
    </article>
  </main>
  <Footer regionFull={footerRegionFull} />
  <FloatingCTA />
</Layout>
