---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import posts from '../../data/wp-posts.json';
import { CHIIKI_REGIONS } from '../../data/blog-chiiki';
import { buildBlogPostJsonLd } from '../../lib/blog-json-ld';
import { normalizeWpContentImageUrls, normalizeWpImageUrl } from '../../lib/wp-image-url';

const fallbackImage = '/hikakutenpo.jpg';

export function getStaticPaths() {
  return posts
    .filter((post) => post.status === 'publish')
    .map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const formatDate = (value) => value.split(' ')[0].replace(/-/g, '.');
const normalizedContent = normalizeWpContentImageUrls(post.content);

let footerRegionFull: string | undefined;
for (const c of post.categories || []) {
  const m = CHIIKI_REGIONS.find((r) => r.categoryLabel === c);
  if (m) {
    footerRegionFull = m.name;
    break;
  }
}

const blogJsonLd = buildBlogPostJsonLd({
  slug: post.slug,
  title: post.title,
  description: post.title,
  datePublished: post.date
});
---

<Layout
  title={`${post.title}｜アイエヌエス車内清掃`}
  description={post.title}
  canonical={`/blog/${post.slug}/`}
  jsonLd={blogJsonLd}
>
  <Header />
  <main class="bg-white">
    <article class="max-w-3xl mx-auto px-6 py-12">
      <p class="text-xs text-gray-500">{formatDate(post.date)}</p>
      <h1 class="mt-2 text-3xl font-bold">{post.title}</h1>
      <div class="mt-4 text-xs text-gray-500">{post.categories?.join(' / ')}</div>
      
      {post.thumbnail && (
        <div class="mt-8 mb-8">
          <img
            src={normalizeWpImageUrl(post.thumbnail)}
            alt={post.title}
            class="w-full max-w-3xl rounded-xl shadow-md object-cover"
            onerror={`this.onerror=null;this.src='${fallbackImage}';`}
          />
        </div>
      )}

      <div class="mt-8 prose max-w-none wp-content" set:html={normalizedContent}></div>
    </article>
  </main>
  <Footer regionFull={footerRegionFull} />
  <FloatingCTA />
</Layout>

<script define:vars={{ fallbackImage }}>
  const contentImages = document.querySelectorAll('.wp-content img');
  contentImages.forEach((img) => {
    img.addEventListener('error', () => {
      if (img.getAttribute('src') !== fallbackImage) {
        img.setAttribute('src', fallbackImage);
      }
    });
  });
</script>
