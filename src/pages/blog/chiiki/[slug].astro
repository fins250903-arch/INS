---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FloatingCTA from '../../../components/FloatingCTA.astro';
import BlogCta from '../../../components/BlogCta.astro';
import { CHIIKI_REGIONS } from '../../../data/blog-chiiki';
import { buildPageJsonLd } from '../../../lib/json-ld-site';
import {
  formatBlogDateLong,
  getBlogPath,
  getPublishedBlogPosts,
  getAreaLabel
} from '../../../lib/blog-content';

export async function getStaticPaths() {
  return CHIIKI_REGIONS.map((region) => ({
    params: { slug: region.slug },
    props: { region }
  }));
}

interface Props {
  region: (typeof CHIIKI_REGIONS)[number];
}

const { region } = Astro.props;

const published = await getPublishedBlogPosts();
const filtered = published
  .filter((post) => post.data.categories.includes(region.categoryLabel))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fallbackArticles: { title: string; region: string; slug: string }[] = [
  { title: '車内で嘔吐！でも大丈夫な対応方法', region: 'fukuoka', slug: 'outo1' },
  { title: '知らなかった！やってはいけない嘔吐物処理とは', region: 'fukuoka', slug: 'outo2' },
  {
    title: '【実証済み】愛車のニオイ撃退！プロが教える車内徹底消臭クリーニング術',
    region: 'fukuoka',
    slug: 'no1'
  }
];

const chiikiJsonLd = buildPageJsonLd({
  path: `/blog/chiiki/${region.slug}/`,
  title: `${region.name}の記事一覧｜ブログ`,
  description: `${region.name}向けにカテゴリ分けしたブログ記事一覧です。`,
  pageType: 'CollectionPage'
});
---

<Layout
  title={`${region.name}の記事一覧｜ブログ`}
  description={`${region.name}向けにカテゴリ分けしたブログ記事一覧です。`}
  canonical={`/blog/chiiki/${region.slug}/`}
  jsonLd={chiikiJsonLd}
>
  <Header />
  <main class="bg-white">
    <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-12">
      <nav class="text-sm text-gray-500">
        <a href="/blog/" class="underline hover:text-primary">ブログ一覧</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800">{region.name}</span>
      </nav>
      <h1 class="mt-4 text-2xl font-bold sm:text-3xl">{region.name}の記事</h1>
      <p class="mt-2 text-sm leading-relaxed text-gray-600">
        カテゴリ「{region.categoryLabel}」が付いた記事を表示しています。
      </p>

      {
        filtered.length > 0 ? (
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {filtered.map((post) => (
              <a
                href={getBlogPath(post)}
                class="block rounded-xl border border-gray-200 p-4 transition hover:shadow"
              >
                <div class="text-xs text-gray-500">{formatBlogDateLong(post.data.date)}</div>
                <div class="mt-2 font-semibold leading-snug text-gray-900">{post.data.title}</div>
                <div class="mt-2 text-xs text-gray-500">{getAreaLabel(post)}</div>
              </a>
            ))}
          </div>
        ) : (
          <div class="mt-8 rounded-xl border border-amber-100 bg-amber-50/80 p-6 text-gray-800">
            <p class="font-semibold">この都道府県カテゴリの記事はまだありません。</p>
            <p class="mt-2 text-sm leading-relaxed">
              内容が同じ解説記事は代表記事への案内を表示します。
            </p>
            <ul class="mt-4 list-disc space-y-2 pl-5 text-sm">
              {fallbackArticles.map((article) => (
                <li>
                  <a
                    href={`/blog/${article.region}/${article.slug}/`}
                    class="font-medium text-primary underline hover:no-underline"
                  >
                    {article.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </section>

    <BlogCta regionFull={region.name} />
  </main>
  <Footer regionFull={region.name} />
  <FloatingCTA />
</Layout>
