---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import posts from '../../data/wp-posts.json';
import { CHIIKI_REGIONS } from '../../data/blog-chiiki';
import { buildPageJsonLd } from '../../lib/json-ld-site';
import { normalizeWpImageUrl } from '../../lib/wp-image-url';

const fallbackImage = '/hikakutenpo.jpg';
const published = posts.filter((post) => post.status === 'publish');
const categories = Array.from(new Set(published.flatMap((post) => post.categories || [])));
const regionCategories = ['大阪', '京都', '群馬', '茨城'];
const otherCategories = categories.filter((cat) => !regionCategories.includes(cat));

const formatDate = (value) => value.split(' ')[0].replace(/-/g, '.');
const blogIndexJsonLd = buildPageJsonLd({
  path: '/blog/',
  title: 'ブログ一覧｜アイエヌエス車内清掃',
  description: 'カテゴリ・作業エリア別に整理した車内清掃のブログ記事一覧です。',
  pageType: 'CollectionPage'
});
---

<Layout
  title="ブログ一覧｜アイエヌエス車内清掃"
  description="カテゴリ・作業エリア別に整理した車内清掃のブログ記事一覧です。"
  canonical="/blog/"
  jsonLd={blogIndexJsonLd}
>
  <Header />
  <main class="bg-white">
    <section class="max-w-6xl mx-auto px-6 py-12">
      <h1 class="text-3xl font-bold">投稿ブログ一覧</h1>
      <p class="mt-2 text-sm text-gray-600">カテゴリ・作業エリア別に整理しています。</p>

      <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {published.map((post) => (
          <a href={`/blog/${post.slug}/`} class="flex flex-col h-full rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition bg-white">
            {post.thumbnail ? (
              <div class="w-full h-48 bg-gray-100 shrink-0">
                <img
                  src={normalizeWpImageUrl(post.thumbnail)}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror={`this.onerror=null;this.src='${fallbackImage}';`}
                />
              </div>
            ) : (
              <div class="w-full h-48 bg-gray-100 shrink-0 flex items-center justify-center">
                <span class="text-gray-400 text-sm">No Image</span>
              </div>
            )}
            <div class="p-5 flex flex-col flex-grow">
              <div class="text-xs text-gray-500 mb-2">{formatDate(post.date)}</div>
              <div class="font-bold text-gray-900 line-clamp-2 leading-snug mb-3">{post.title}</div>
              <div class="mt-auto text-xs font-medium text-blue-600 bg-blue-50 w-fit px-2 py-1 rounded">{post.categories?.[0] || 'Blog'}</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="bg-gray-50">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <h2 class="text-2xl font-bold">都道府県別ブログ</h2>
        <p class="mt-2 text-sm text-gray-600">
          記事のカテゴリ（都道府県名）ごとの一覧です。該当が無い県は代表記事への案内を表示します。
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {CHIIKI_REGIONS.map((r) => (
            <a href={`/blog/chiiki/${r.slug}/`} class="rounded-full border bg-white px-3 py-1.5 text-sm hover:border-primary">
              {r.name}
            </a>
          ))}
        </div>

        <h2 class="mt-10 text-2xl font-bold">作業エリア別（従来カテゴリ）</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {regionCategories.map((cat) => (
            <a href={`/blog/category/${cat}/`} class="rounded-full border px-4 py-2 text-sm">{cat}</a>
          ))}
        </div>

        <h2 class="mt-10 text-2xl font-bold">カテゴリ別</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {otherCategories.map((cat) => (
            <a href={`/blog/category/${cat}/`} class="rounded-full border px-4 py-2 text-sm">{cat}</a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <FloatingCTA />
</Layout>
