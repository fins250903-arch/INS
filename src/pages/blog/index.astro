---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import BlogCta from '../../components/BlogCta.astro';
import { BLOG_REGIONS } from '../../data/blog-regions';
import { CHIIKI_REGIONS } from '../../data/blog-chiiki';
import { buildPageJsonLd } from '../../lib/json-ld-site';
import {
  formatBlogDate,
  getAllBlogCategories,
  getAreaLabel,
  getBlogPath,
  getPublishedBlogPosts,
  groupPostsByRegion,
  resolveBlogImage
} from '../../lib/blog-content';

const allPosts = await getPublishedBlogPosts();
const grouped = groupPostsByRegion(allPosts);
const categories = getAllBlogCategories(allPosts);
const regionCategories = ['大阪', '京都', '群馬', '茨城'];
const otherCategories = categories.filter((cat) => !regionCategories.includes(cat));

const activeRegion = Astro.url.searchParams.get('region') || '';
const filteredPosts = activeRegion
  ? allPosts.filter((post) => post.data.region === activeRegion)
  : allPosts;

const blogIndexJsonLd = buildPageJsonLd({
  path: '/blog/',
  title: 'ブログ一覧｜アイエヌエス車内清掃',
  description: '地域別・カテゴリ別に整理した車内清掃のブログ記事一覧です。',
  pageType: 'CollectionPage'
});

// 新着順にソート
const sortedPosts = posts.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout
  title="ブログ一覧｜アイエヌエス車内清掃"
  description="地域別・カテゴリ別に整理した車内清掃のブログ記事一覧です。"
  canonical="/blog/"
  jsonLd={blogIndexJsonLd}
>
  <Header />
  <main class="bg-white">
    <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-12">
      <h1 class="text-2xl font-bold sm:text-3xl">投稿ブログ一覧</h1>
      <p class="mt-2 text-sm leading-relaxed text-gray-600">
        地域サイト別・カテゴリ別に整理しています。スマホでも読みやすい一覧です。
      </p>

      <div class="mt-6 flex flex-wrap justify-center gap-2 sm:justify-start">
        <a
          href="/blog/"
          class:list={[
            'rounded-full border px-3 py-1.5 text-sm transition',
            !activeRegion ? 'border-primary bg-primary/10 font-semibold text-primary' : 'bg-white hover:border-primary'
          ]}
        >
          すべて
        </a>
        {BLOG_REGIONS.map((region) => (
          <a
            href={`/blog/?region=${region.slug}`}
            class:list={[
              'rounded-full border px-3 py-1.5 text-sm transition',
              activeRegion === region.slug
                ? 'border-primary bg-primary/10 font-semibold text-primary'
                : 'bg-white hover:border-primary'
            ]}
          >
            {region.regionFull}
          </a>
        ))}
      </div>

      {
        activeRegion ? (
          <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {filteredPosts.map((post) => {
              const thumb = resolveBlogImage(post.data.thumbnail);
              return (
                <a
                  href={getBlogPath(post)}
                  class="flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-white transition hover:shadow-lg"
                >
                  {thumb ? (
                    <div class="h-44 w-full shrink-0 bg-gray-100">
                      <img src={thumb} alt="" class="h-full w-full object-cover" loading="lazy" />
                    </div>
                  ) : (
                    <div class="flex h-44 w-full shrink-0 items-center justify-center bg-gray-100">
                      <span class="text-sm text-gray-400">No Image</span>
                    </div>
                  )}
                  <div class="flex flex-grow flex-col p-4 sm:p-5">
                    <div class="mb-2 text-xs text-gray-500">{formatBlogDate(post.data.date)}</div>
                    <div class="mb-3 line-clamp-2 font-bold leading-snug text-gray-900">{post.data.title}</div>
                    <div class="mt-auto w-fit rounded bg-blue-50 px-2 py-1 text-xs font-medium text-blue-600">
                      {getAreaLabel(post)}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          BLOG_REGIONS.map((region) => {
            const posts = grouped.get(region.slug) || [];
            if (posts.length === 0) return null;
            return (
              <section class="mt-10">
                <div class="flex flex-col items-center gap-2 text-center sm:flex-row sm:justify-between sm:text-left">
                  <h2 class="text-xl font-bold sm:text-2xl">{region.regionFull}の記事</h2>
                  <a href={`/blog/region/${region.slug}/`} class="text-sm font-medium text-primary underline">
                    {region.regionFull}の一覧を見る
                  </a>
                </div>
                <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                  {posts.slice(0, 6).map((post) => {
                    const thumb = resolveBlogImage(post.data.thumbnail);
                    return (
                      <a
                        href={getBlogPath(post)}
                        class="flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-white transition hover:shadow-lg"
                      >
                        {thumb ? (
                          <div class="h-40 w-full shrink-0 bg-gray-100">
                            <img src={thumb} alt="" class="h-full w-full object-cover" loading="lazy" />
                          </div>
                        ) : (
                          <div class="flex h-40 w-full shrink-0 items-center justify-center bg-gray-100">
                            <span class="text-sm text-gray-400">No Image</span>
                          </div>
                        )}
                        <div class="flex flex-grow flex-col p-4">
                          <div class="mb-2 text-xs text-gray-500">{formatBlogDate(post.data.date)}</div>
                          <div class="line-clamp-2 font-semibold leading-snug text-gray-900">{post.data.title}</div>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </section>
            );
          })
        )
      }
    </section>

    <BlogCta />

    <section class="bg-gray-50">
      <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-12">
        <h2 class="text-xl font-bold sm:text-2xl">地域サイト別</h2>
        <div class="mt-4 flex flex-wrap justify-center gap-2 sm:justify-start">
          {BLOG_REGIONS.map((region) => (
            <a
              href={`/blog/region/${region.slug}/`}
              class="rounded-full border bg-white px-3 py-1.5 text-sm hover:border-primary"
            >
              {region.regionFull}
            </a>
          ))}
        </div>

        <h2 class="mt-10 text-xl font-bold sm:text-2xl">都道府県別ブログ</h2>
        <p class="mt-2 text-sm leading-relaxed text-gray-600">
          記事のカテゴリ（都道府県名）ごとの一覧です。
        </p>
        <div class="mt-4 flex flex-wrap justify-center gap-2 sm:justify-start">
          {CHIIKI_REGIONS.map((r) => (
            <a href={`/blog/chiiki/${r.slug}/`} class="rounded-full border bg-white px-3 py-1.5 text-sm hover:border-primary">
              {r.name}
            </a>
          ))}
        </div>

        {regionCategories.length > 0 && (
          <>
            <h2 class="mt-10 text-xl font-bold sm:text-2xl">作業エリア別（従来カテゴリ）</h2>
            <div class="mt-4 flex flex-wrap justify-center gap-2 sm:justify-start">
              {regionCategories.map((cat) => (
                <a href={`/blog/category/${encodeURIComponent(cat)}/`} class="rounded-full border px-4 py-2 text-sm">
                  {cat}
                </a>
              ))}
            </div>
          </>
        )}

        {otherCategories.length > 0 && (
          <>
            <h2 class="mt-10 text-xl font-bold sm:text-2xl">カテゴリ別</h2>
            <div class="mt-4 flex flex-wrap justify-center gap-2 sm:justify-start">
              {otherCategories.map((cat) => (
                <a href={`/blog/category/${encodeURIComponent(cat)}/`} class="rounded-full border px-4 py-2 text-sm">
                  {cat}
                </a>
              ))}
            </div>
          </>
        )}
      </div>
    </section>
  </main>
  <Footer />
  <FloatingCTA />
</Layout>
