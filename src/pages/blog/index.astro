---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "特急便 施工実績ブログ",
  "description": "日本全国の出張デッドニング・スピーカー取付の施工事例をご紹介します。"
};
---

<Layout 
  title="施工実績ブログ | 車の出張パーツ取付 特急便" 
  description="デッドニングやスピーカー交換のリアルな施工風景をご紹介。滋賀、大阪、兵庫など各地域での事例を掲載中。" 
  canonical="https://deadning.abura.site/blog/"
  region="blog"
  jsonLd={jsonLd}
>
	<section class="blog-index">
    <div class="container">
      <h1 class="section-title">施工実績ブログ</h1>
      <div class="blog-grid">
        {posts.map((post) => {
          const slug = post.id.replace(/\/index$/, '');
          return (
            <a href={`/blog/${slug}/`} class="blog-card">
              {(post.data.heroImage || post.data.coverImage) && (
                <img 
                  src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage?.src || post.data.coverImage} 
                  alt="" 
                  class="card-image" 
                />
              )}
              <div class="card-content">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <span class="date">{(post.data.pubDate || post.data.date)?.toLocaleDateString('ja-JP')}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
	</section>
</Layout>

<style>
  .blog-index {
    padding: 60px 0;
    background: #f8f9fb;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    margin-top: 40px;
  }
  .blog-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    text-decoration: none;
    transition: transform 0.2s;
  }
  .blog-card:hover {
    transform: translateY(-5px);
  }
  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .card-content {
    padding: 20px;
  }
  .card-content h3 {
    font-size: 18px;
    font-weight: 900;
    margin-bottom: 10px;
    color: var(--color-primary);
  }
  .card-content p {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 15px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .date {
    font-size: 12px;
    color: var(--color-gold);
    font-weight: 700;
  }
</style>
