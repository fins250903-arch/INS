---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { BLOG_REGIONS } from '../../data/blog-regions';
import {
  clearAdminAuthCookie,
  getAdminPassword,
  isAdminAuthenticated,
  setAdminAuthCookie
} from '../../lib/admin-auth';
import {
  deleteMdPost,
  getAllMdPosts,
  resolvePostThumbnail,
  sortMdPosts
} from '../../lib/blog-md-store';
import { formatBlogDate } from '../../lib/blog-content';

const isAuthenticated = isAdminAuthenticated(Astro.cookies);
let loginError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString() || '';

  if (action === 'login') {
    const submittedPassword = formData.get('password')?.toString() || '';
    if (submittedPassword === getAdminPassword()) {
      setAdminAuthCookie(Astro.cookies);
      return Astro.redirect('/admin/blog-manager/');
    }
    loginError = 'パスワードが間違っています';
  }

  if (action === 'logout' && isAuthenticated) {
    clearAdminAuthCookie(Astro.cookies);
    return Astro.redirect('/admin/blog-manager/');
  }

  if (isAuthenticated && action === 'delete') {
    const region = formData.get('region')?.toString() || '';
    const slug = formData.get('slug')?.toString() || '';
    if (region && slug) {
      deleteMdPost(region, slug);
      return Astro.redirect('/admin/blog-manager/');
    }
  }
}

const sortOrder = (Astro.url.searchParams.get('sort') === 'asc' ? 'asc' : 'desc') as
  | 'asc'
  | 'desc';
const regionFilter = Astro.url.searchParams.get('region') || '';

const allPosts = isAuthenticated ? getAllMdPosts() : [];
const filteredPosts = regionFilter
  ? allPosts.filter((post) => post.region === regionFilter)
  : allPosts;
const sortedPosts = sortMdPosts(filteredPosts, sortOrder);
---

<Layout
  title="ブログ管理画面"
  description="ブログ記事を管理する画面です"
  canonical="/admin/blog-manager/"
>
  <main class="min-h-screen bg-slate-50">
    {
      !isAuthenticated ? (
        <div class="flex min-h-screen items-center justify-center px-4">
          <div class="w-full max-w-md rounded-2xl bg-white p-8 shadow-xl">
            <h1 class="mb-2 text-center text-2xl font-bold text-slate-900">ブログ管理ログイン</h1>
            <p class="mb-6 text-center text-sm text-slate-500">Astroブログ記事の作成・編集</p>

            {loginError && (
              <div class="mb-4 rounded-lg bg-red-50 p-3 text-sm text-red-700">{loginError}</div>
            )}

            <form method="POST" class="space-y-4">
              <input type="hidden" name="action" value="login" />
              <div>
                <label for="password" class="mb-2 block text-sm font-medium text-slate-700">
                  パスワード
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  class="w-full rounded-lg border border-slate-300 px-4 py-2.5 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
                  required
                  autofocus
                />
              </div>
              <button
                type="submit"
                class="w-full rounded-lg bg-blue-600 py-2.5 font-medium text-white transition hover:bg-blue-700"
              >
                ログイン
              </button>
            </form>
          </div>
        </div>
      ) : (
        <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
          <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h1 class="text-3xl font-bold text-slate-900">ブログ管理</h1>
              <p class="mt-1 text-sm text-slate-500">全 {sortedPosts.length} 件の記事</p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
              <a
                href="/admin/blog-manager/edit/"
                class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-blue-700"
              >
                + 新規記事作成
              </a>
              <a
                href="/admin/"
                class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 transition hover:bg-slate-50"
              >
                Decap CMS
              </a>
              <a href="/blog/" class="text-sm text-blue-600 hover:underline">
                ブログを見る
              </a>
              <form method="POST">
                <input type="hidden" name="action" value="logout" />
                <button type="submit" class="text-sm text-red-600 hover:underline">
                  ログアウト
                </button>
              </form>
            </div>
          </div>

          <div class="mb-6 flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-sm font-medium text-slate-600">地域フィルター:</span>
              <a
                href={`/admin/blog-manager/?sort=${sortOrder}`}
                class:list={[
                  'rounded-full border px-3 py-1 text-sm transition',
                  !regionFilter
                    ? 'border-blue-600 bg-blue-50 font-semibold text-blue-700'
                    : 'border-slate-200 bg-white text-slate-600 hover:border-blue-300'
                ]}
              >
                すべて
              </a>
              {BLOG_REGIONS.map((region) => (
                <a
                  href={`/admin/blog-manager/?region=${region.slug}&sort=${sortOrder}`}
                  class:list={[
                    'rounded-full border px-3 py-1 text-sm transition',
                    regionFilter === region.slug
                      ? 'border-blue-600 bg-blue-50 font-semibold text-blue-700'
                      : 'border-slate-200 bg-white text-slate-600 hover:border-blue-300'
                  ]}
                >
                  {region.regionFull}
                </a>
              ))}
            </div>

            <div class="flex items-center gap-2">
              <label for="sort-select" class="text-sm font-medium text-slate-600">
                並び替え:
              </label>
              <select
                id="sort-select"
                class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
              >
                <option value="desc" selected={sortOrder === 'desc'}>
                  新しい順
                </option>
                <option value="asc" selected={sortOrder === 'asc'}>
                  古い順
                </option>
              </select>
            </div>
          </div>

          {sortedPosts.length === 0 ? (
            <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
              <p class="text-slate-500">記事がありません</p>
              <a
                href="/admin/blog-manager/edit/"
                class="mt-4 inline-block text-blue-600 hover:underline"
              >
                最初の記事を作成する
              </a>
            </div>
          ) : (
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {sortedPosts.map((post) => {
                const thumb = resolvePostThumbnail(post);
                const areaLabel = post.areaLabel || post.regionFull;
                return (
                  <article class="group flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition hover:shadow-lg">
                    <a href={`/admin/blog-manager/edit/?region=${post.region}&slug=${post.slug}`}>
                      {thumb ? (
                        <div class="aspect-[16/10] w-full overflow-hidden bg-slate-100">
                          <img
                            src={thumb}
                            alt=""
                            class="h-full w-full object-cover transition group-hover:scale-105"
                            loading="lazy"
                          />
                        </div>
                      ) : (
                        <div class="flex aspect-[16/10] w-full items-center justify-center bg-slate-100">
                          <span class="text-sm text-slate-400">No Image</span>
                        </div>
                      )}
                    </a>

                    <div class="flex flex-grow flex-col p-4">
                      <div class="mb-2 flex items-center justify-between gap-2">
                        <time class="text-xs text-slate-500" datetime={post.date}>
                          {formatBlogDate(post.date)}
                        </time>
                        <span
                          class:list={[
                            'rounded-full px-2 py-0.5 text-xs font-medium',
                            post.draft
                              ? 'bg-amber-100 text-amber-800'
                              : 'bg-emerald-100 text-emerald-800'
                          ]}
                        >
                          {post.draft ? '下書き' : '公開'}
                        </span>
                      </div>

                      <h2 class="mb-2 line-clamp-2 text-sm font-bold leading-snug text-slate-900">
                        <a
                          href={`/admin/blog-manager/edit/?region=${post.region}&slug=${post.slug}`}
                          class="hover:text-blue-600"
                        >
                          {post.title}
                        </a>
                      </h2>

                      <div class="mt-auto flex flex-wrap items-center gap-2">
                        <span class="rounded bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700">
                          {areaLabel}
                        </span>
                        {post.categories.slice(0, 2).map((cat) => (
                          <span class="rounded bg-slate-100 px-2 py-0.5 text-xs text-slate-600">
                            {cat}
                          </span>
                        ))}
                      </div>

                      <div class="mt-3 flex gap-2 border-t border-slate-100 pt-3">
                        <a
                          href={`/admin/blog-manager/edit/?region=${post.region}&slug=${post.slug}`}
                          class="flex-1 rounded-lg bg-slate-100 py-1.5 text-center text-xs font-medium text-slate-700 transition hover:bg-slate-200"
                        >
                          編集
                        </a>
                        <a
                          href={`/blog/${post.region}/${post.slug}/`}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex-1 rounded-lg border border-slate-200 py-1.5 text-center text-xs font-medium text-slate-600 transition hover:bg-slate-50"
                        >
                          表示
                        </a>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          )}
        </div>
      )
    }
  </main>

  <script>
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
    if (sortSelect) {
      sortSelect.addEventListener('change', () => {
        const url = new URL(window.location.href);
        url.searchParams.set('sort', sortSelect.value);
        window.location.href = url.toString();
      });
    }
  </script>
</Layout>
