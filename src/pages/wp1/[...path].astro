---
export const prerender = false;

const rawHost = Astro.request.headers.get('x-forwarded-host') || Astro.url.hostname;
const host = rawHost.toLowerCase();
const path = Astro.params.path || '';

let region = 'osaka';
if (host.includes('hyg')) region = 'hyougo';
if (host.includes('siga')) region = 'siga';

const destination = path ? `https://insbs.net/${region}/${path}` : `https://insbs.net/${region}/`;

return Astro.redirect(destination, 301);
---
