---
export const prerender = false;

import { resolveWp1Region } from '../../../lib/wp1-region-redirect';

const rawHost = Astro.request.headers.get('x-forwarded-host') || Astro.url.hostname;
const path = Astro.params.path || '';
const { region } = resolveWp1Region(rawHost, path);

const destination = path
  ? `https://insbs.net/blog/${path}`
  : `https://insbs.net/blog/chiiki/${region}/`;

return Astro.redirect(destination, 301);
---
