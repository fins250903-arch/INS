---
// CtaBundle.astro
interface Props {
  className?: string;
}
const { className = '' } = Astro.props;
---
<div class={`cta-bundle-box ${className}`}>
  <div class="cta-attention">
    <span>＼ 今だけ限定！迷っている方へ ／</span>
  </div>
  <div class="cta-benefit">
    <span class="cta-benefit-badge">限定特典</span>
    <p class="cta-benefit-text">
      抗菌コート 今月末まで <span class="cta-highlight">無料</span> <span class="cta-subtext">（通常￥2,000）</span>
    </p>
  </div>
  <div class="cta-action-area">
    <a href="tel:070-8428-0866" class="cta-btn">
      <span class="cta-btn-sub">365日24時間受付中・見積り無料</span>
      <span class="cta-btn-main">
        <svg class="cta-phone-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        無料見積り・今すぐ相談する
      </span>
      <span class="cta-btn-tel">TEL: 070-8428-0866</span>
    </a>
    <p class="cta-micro-copy">スマホならタップで直接お電話がつながります</p>
  </div>
</div>

<style>
  .cta-bundle-box {
    background: linear-gradient(135deg, #ffffff 0%, #f9fbfd 100%);
    border: 3px solid #A5C33A; /* プライマリーカラーの緑 */
    border-radius: 1.25rem;
    padding: 1.75rem 1.5rem;
    box-shadow: 0 15px 30px rgba(165, 195, 58, 0.15), 0 5px 15px rgba(0, 0, 0, 0.05);
    text-align: center;
    max-width: 500px;
    margin: 1.5rem auto;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease;
  }
  
  .cta-bundle-box:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 35px rgba(165, 195, 58, 0.22), 0 8px 25px rgba(0, 0, 0, 0.08);
  }

  .cta-attention {
    background-color: #A5C33A;
    color: #ffffff;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.35rem 1.25rem;
    border-radius: 9999px;
    display: inline-block;
    margin-bottom: 0.85rem;
    letter-spacing: 0.05em;
    box-shadow: 0 4px 6px rgba(165, 195, 58, 0.2);
  }

  .cta-benefit {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .cta-benefit-badge {
    background-color: #dd0606; /* 警告赤 */
    color: #ffffff;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .cta-benefit-text {
    font-size: 1.25rem;
    font-weight: 800;
    color: #333333;
    margin: 0;
    line-height: 1.4;
  }

  .cta-highlight {
    color: #dd0606;
    font-size: 1.65rem;
    font-weight: 900;
    text-decoration: underline;
    text-decoration-color: #ffc107;
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
    margin: 0 0.2rem;
    display: inline-block;
    animation: cta-pulse-glow 2s infinite ease-in-out;
  }

  .cta-subtext {
    font-size: 0.95rem;
    color: #666666;
    font-weight: 700;
  }

  .cta-action-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .cta-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #dd0606 0%, #b80505 100%);
    color: #ffffff !important;
    width: 100%;
    padding: 0.9rem 1.2rem;
    border-radius: 9999px;
    font-weight: 800;
    text-decoration: none !important;
    box-shadow: 0 8px 20px rgba(221, 6, 6, 0.35);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    border: 2px solid rgba(255, 255, 255, 0.15);
    position: relative;
    overflow: hidden;
  }

  /* 光沢アニメーション */
  .cta-btn::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -60%;
    width: 30%;
    height: 200%;
    background: rgba(255, 255, 255, 0.3);
    transform: rotate(30deg);
    transition: none;
    animation: cta-shine 4s infinite ease-in-out;
  }

  .cta-btn:hover {
    background: linear-gradient(135deg, #ff1a1a 0%, #dd0606 100%);
    transform: scale(1.03);
    box-shadow: 0 12px 25px rgba(221, 6, 6, 0.45);
  }

  .cta-btn-sub {
    font-size: 0.75rem;
    opacity: 0.95;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .cta-btn-main {
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    letter-spacing: 0.02em;
    font-weight: 900;
  }

  .cta-phone-icon {
    width: 1.5rem;
    height: 1.5rem;
    animation: cta-phone-shake 1.8s infinite ease-in-out;
  }

  .cta-btn-tel {
    font-size: 1.25rem;
    margin-top: 0.25rem;
    font-family: 'Lato', sans-serif;
    border-top: 1px dashed rgba(255, 255, 255, 0.4);
    padding-top: 0.2rem;
    width: 85%;
    letter-spacing: 0.08em;
    font-weight: 800;
  }

  .cta-micro-copy {
    font-size: 0.75rem;
    color: #555555;
    margin-top: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  /* アニメーション定義 */
  @keyframes cta-shine {
    0% { left: -60%; }
    15% { left: 130%; }
    100% { left: 130%; }
  }

  @keyframes cta-phone-shake {
    0%, 100% { transform: rotate(0); }
    10%, 30%, 50% { transform: rotate(-15deg); }
    20%, 40% { transform: rotate(15deg); }
    60% { transform: rotate(0); }
  }

  @keyframes cta-pulse-glow {
    0%, 100% { transform: scale(1); filter: drop-shadow(0 0 1px rgba(221, 6, 6, 0.2)); }
    50% { transform: scale(1.04); filter: drop-shadow(0 0 6px rgba(221, 6, 6, 0.5)); }
  }

  @media (max-width: 767px) {
    .cta-bundle-box {
      padding: 1.4rem 1.2rem;
      margin: 1.2rem auto;
      border-radius: 1rem;
    }
    .cta-benefit-text {
      font-size: 1.1rem;
    }
    .cta-highlight {
      font-size: 1.4rem;
    }
    .cta-btn-main {
      font-size: 1.15rem;
    }
    .cta-btn-tel {
      font-size: 1.15rem;
    }
    .cta-attention {
      font-size: 0.8rem;
      padding: 0.25rem 1rem;
    }
  }
</style>
