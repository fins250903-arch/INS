---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import AntimicrobialCampaignBanner from './AntimicrobialCampaignBanner.astro';
import CtaBundle from './CtaBundle.astro';
import posts from '../data/wp-posts.json';
import { osakaServiceAreas } from '../data/service-areas/osaka';
import { additionalNotes, pricingOptions, pricingPartial, pricingSet } from '../data/lp-pricing';
import { buildRegionFaqs } from '../data/lp-faqs';
import { CONTACT_EMAIL, CONTACT_MAILTO, SITE_CONTENT_UPDATED } from '../data/site';
import type { CaseStudiesBlock } from '../data/lp-region-case-studies';
import bgHero from '../assets/images/images-1-e1756888161530.jpg';
import ctaBg from '../assets/images/carclean15kb.jpg';
import worryDrink from '../assets/images/嘔吐シミダレ-1.jpg';
import worryCeiling from '../assets/images/tennjyo.jpg';
import worrySeat from '../assets/images/シート.jpg';
import voice01 from '../assets/images/202604-724x1024.jpg';
import voice02 from '../assets/images/202603-724x1024.jpg';
import voice03 from '../assets/images/202602-scaled.jpg';
import voice04 from '../assets/images/お客様の声2602-scaled.jpg';
import voice05 from '../assets/images/車前-3人並び喜ぶ.jpg';
import voice06 from '../assets/images/放尿260206.jpg';
import voice07 from '../assets/images/ふまん-2601-scaled.jpg';
import voice08 from '../assets/images/お客様の声1-2510.jpg';
import voice09 from '../assets/images/gasosut-251012-scaled.jpg';
import voice10 from '../assets/images/お客様の声2508.jpg';
import voice11 from '../assets/images/軽四お客様喜び-1024x559.jpg';
import commentPhoto from '../assets/images/car_zaseki_pikapika.jpg';
import defaultRepresentative from '../assets/images/representative-new.png';
interface ServiceAreaRow {
  label: string;
  text: string;
}

interface Props {
  regionName?: string;
  regionFull?: string;
  showAreaList?: boolean;
  /** 未指定時は大阪エリア一覧（osakaServiceAreas） */
  serviceAreas?: ServiceAreaRow[];
  /** `src/assets/images/` 直下のファイル名（例: representative-nara.png）。無ければデフォルト画像。 */
  representativeImageFile?: string;
  /** 出張エリア見出し直下のリード文を全文差し替え（未指定時は大阪府向け／その他県向けの定型文） */
  areaLead?: string;
  /** 地域ごとの施工事例・ブログへのテキストリンク（AI検索・重複軽減用） */
  caseStudies?: CaseStudiesBlock;
  /** 地区FAQ・JSON-LD用（例: osaka, aiti, tokyou） */
  regionSlug?: string;
}

const {
  regionName = '大阪',
  regionFull = '大阪府',
  showAreaList = true,
  serviceAreas: serviceAreasProp,
  representativeImageFile,
  areaLead,
  caseStudies,
  regionSlug
} = Astro.props;

const serviceHeadingTarget = regionFull === '沖縄県' ? '沖縄本島' : regionFull;
const areaListTitlePrefix = regionFull === '沖縄県' ? '沖縄本島' : regionFull;

const representativeGlob = import.meta.glob<ImageMetadata>('../assets/images/representative*.png', {
  eager: true,
  import: 'default'
});

const ownerPhoto = (() => {
  if (!representativeImageFile?.trim()) return defaultRepresentative;
  const name = representativeImageFile.trim();
  const hit = Object.keys(representativeGlob).find((k) => {
    const norm = k.replace(/\\/g, '/');
    return norm.endsWith('/' + name) || norm.endsWith(name);
  });
  return hit ? representativeGlob[hit] : defaultRepresentative;
})();

const serviceAreas: ServiceAreaRow[] = serviceAreasProp ?? [...osakaServiceAreas];

const publishedPosts = posts.filter((post) => post.status === 'publish');

const regionKeywords = [regionName, regionFull]
  .map((value) => value?.trim())
  .filter((value): value is string => Boolean(value));

const hasRegionKeyword = (content?: string) => {
  if (!content || regionKeywords.length === 0) return false;
  return regionKeywords.some((keyword) => content.includes(keyword));
};

const regionPosts = publishedPosts.filter((post) => hasRegionKeyword(post.content));

const blogPosts = (regionPosts.length > 0 ? regionPosts : publishedPosts)
  .sort((a, b) => (a.date < b.date ? 1 : -1))
  .slice(0, 6);

const surveyItems = [
  {
    image: voice01,
    alt: '60代男 母を乗せた際におもらしがあり、シートの奥まで染みてしまいました。自分では表面しか拭けず臭いが残っていましたが、高温スチームで奥まで除菌してもらい解消しました。',
    text: '60代男 母を乗せた際におもらしがあり、シートの奥まで染みてしまいました。自分では表面しか拭けず臭いが残っていましたが、高温スチームで奥まで除菌してもらい解消しました。'
  },
  {
    image: voice02,
    alt: '30代 放置していた食べこぼしからカビが発生。不衛生で子供を乗せられませんでしたが、徹底洗浄と除菌でピカピカに。これからは車内での飲食に気をつけます。',
    text: '30代 放置していた食べこぼしからカビが発生。不衛生で子供を乗せられませんでしたが、徹底洗浄と除菌でピカピカに。これからは車内での飲食に気をつけます。'
  },
  {
    image: voice03,
    alt: '売却前に査定を上げたくてヤニ取り清掃を依頼。見た目の清潔感が格段に上がり、予想以上の査定額がつきました。クリーニング代を払ってもお釣りがきました。40代',
    text: '売却前に査定を上げたくてヤニ取り清掃を依頼。見た目の清潔感が格段に上がり、予想以上の査定額がつきました。クリーニング代を払ってもお釣りがきました。40代'
  }
];

const needsList = [
  '嘔吐（ゲロ）そうじ / 子供、ペットが車酔い お酒の飲み過ぎ',
  '灯油やオイル臭 / 運んでいる途中で、車内にこぼれた',
  '中古車クリーニング、変なニオイ',
  'ペットの毛・ニオイ / シートにくっついて取れない。独特なニオイもする。',
  'ヤニ・タバコ臭 / 車内にシミもあり、友人を乗せたらクサイと言われた。',
  '車を持込んで、清掃してもらう時間が取れない。',
  'お客さんを乗せるから、早くキレイに車内を清掃して欲しい',
  '中古車 芳香剤の匂い を消してほしい',
  '※灯油、ネコのおしっこ のニオイは、完全に除去できない場合があります。'
];

const features = [
  '即座に、ご指定場所へ出張し、クリーニング清掃や臭い取り作業を致します。',
  '清掃中は立会不要です。作業完了後、お知らせします。',
  '特殊な洗剤・消臭剤・消臭機を使います。市販の洗剤では落ちないシミやニオイにも対応します。',
  '清掃後は、洗剤が空気と触れ合うと分解されるものを使用します。だから赤ちゃんペットにも安心。'
];

const reasons = [
  '「表面だけ」じゃない。シートの裏まで届く、本物の車内洗浄。市販の消臭スプレーで車内の臭い消しをしようとしても、結局はニオイを上書きしているだけ。時間が経てば、また嫌なニオイが戻ってきてしまいます。当店の車シート洗浄は、ここが違います。',
  '「洗って、吸い出す」という発想：特殊な洗浄機を使い、シート内部に潜む汚れを温水で分解。それを強力なバキュームで一気に吸い上げます。黒く濁った水が出てくるのを見ると、「こんなに汚れていたのか！」と驚かれるはずです。',
  '頑固な付着臭も、根こそぎ：中古車特有の染み付いたニオイや、長年のヤニ・タバコ臭。これらも、天井からフロアまで、プロの技術で車内装クリーニングを施すことで、驚くほどクリアな空間に生まれ変わります。',
  '「ペットの毛」一本まで逃さない：シートに絡みついて取れないペットの毛。指でつまんでもキリがない作業も、専用ツールと車のシート掃除のプロの技で、スッキリ綺麗に取り除きます。'
];

const benefits = [
  '即座に、ご指定場所へ出張訪問し、お見積りします。それから、クリーニング清掃や車内の臭い取り作業を開始します。',
  '作業時間は、2時間程です。ただし、ヨゴレがひどい場合は、4時間くらいかけて徹底洗浄。',
  '365日24時間受付対応致します。お電話、メールでも受け付け可能です。',
  '消臭剤でごまかしません。徹底的に、ヨゴレの原因を落として、キレイにします。'
];

const flowSteps = [
  {
    title: 'お問い合わせ',
    text: 'まずはお気軽にお問い合わせください。お電話・メールでお待ちしております。作業中等で、電話にすぐに出られない場合は、折返しご連絡します。'
  },
  {
    title: '訪問日・作業内容の決定',
    text: '状況をお聞かせいただき、概算をお伝えします。ご希望の日時と駐車場所の状態、全ドアを開けられるスペース、水、電源などの確認や当方の車を停める駐車場の有無などをお伺いいたします。※ただし有料パーキング利用の場合は、別途ご請求となります。'
  },
  {
    title: 'お見積り',
    text: '訪問後、現車の状態を確認します。それからお見積りをお伝えします。'
  },
  {
    title: '清掃',
    text: '了承次第、作業開始します。そして作業完了後、ご報告し、状況をご確認頂きます。'
  },
  {
    title: 'お会計',
    text: 'ご確認完了、状態をご了承後、お支払いお願いします。現金か、銀行振込での決済です。'
  },
  {
    title: '完了',
    text: '快適になった、お車をご利用ください。もし万が一施工後に洗い残し、ニオイ等、気になることが有れば、お知らせください。※灯油、ネコのおしっこニオイは、完全に除去できない場合があります。'
  }
];

const voiceGallery = [
  { image: voice04, caption: '嘔吐クリーニングきれい' },
  { image: voice05, caption: '車内洗浄が終わった車の前で3人写った写真' },
  { image: voice06, caption: '車の中で放尿された' },
  { image: voice07, caption: 'ヤニ汚れが残っていた' },
  { image: voice08, caption: 'シート汚れがきれいで満足' },
  { image: voice09, caption: 'ガソスタ　コーティングのプロよりも正解' },
  { image: voice10, caption: '炎天下の作業ご苦労さまでした　生肉の匂いが取れました。' }
];

const faqs = buildRegionFaqs(regionName, regionFull, regionSlug);

const [updatedYear, updatedMonth, updatedDay] = SITE_CONTENT_UPDATED.split('-');
const contentUpdatedJa = `${updatedYear}年${Number(updatedMonth)}月${Number(updatedDay)}日`;

const formatDate = (value: string) => value.split(' ')[0].replace(/-/g, '.');
---

<section class="relative flex min-h-[min(40rem,90svh)] flex-col justify-center overflow-hidden bg-black text-white">
  <div class="absolute inset-0">
    <Image src={bgHero} alt="背景画像" class="h-full w-full object-cover" />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>
  <div class="relative mx-auto w-full max-w-6xl px-6 py-16 sm:py-20 lg:py-24">
    <div class="flex flex-col gap-8">
      <div>
        <h1 class="fv-title text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
          {regionName} 地元密着｜<br />出張 車内清掃
        </h1>
        <p class="fv-sub mt-5 text-sm font-bold tracking-wide text-white/95 sm:text-base">
          <span class="mr-3 inline-block border-b-2 border-primary pb-0.5">即日訪問</span>
          <span class="mr-3 inline-block border-b-2 border-primary pb-0.5">地元密着</span>
          <span class="inline-block border-b-2 border-primary pb-0.5">実績多数</span>
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-6 rounded-xl bg-black/40 px-5 py-4 backdrop-blur-sm">
          <div class="fv-stamp">
            <span class="fv-stamp-label">顧客満足</span>
            <span class="fv-stamp-value">92%</span>
          </div>
          <p class="fv-desc min-w-[12rem] flex-1 text-base sm:text-lg font-bold leading-relaxed text-white/95">
            365日24時間受付中・迅速訪問<br />
            立会も不要！ <span class="text-amber-300 font-bold">嘔吐</span>、<span class="text-amber-300 font-bold">お漏らし</span><br />
            <span class="text-amber-300 font-bold">灯油こぼし</span>も <span class="text-amber-300 font-bold underline decoration-amber-300">ニオイ徹底洗浄</span>
          </p>
        </div>
        <div class="mt-6 flex justify-start w-full">
          <CtaBundle className="!mx-0 !my-0 w-full max-w-[480px]" />
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-3 bg-slate-100 border-b border-slate-200" aria-label="コンテンツ更新情報">
  <div class="max-w-6xl mx-auto px-6">
    <p class="text-xs sm:text-sm text-slate-600 text-center leading-relaxed">
      <strong>最終更新：{contentUpdatedJa}</strong>｜料金・対応エリア・FAQは定期的に見直しています。
    </p>
  </div>
</section>

<section class="py-10 bg-white border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-xl sm:text-2xl font-bold text-gray-900">出張車内清掃とは</h2>
    <p class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed">
      ご自宅・勤務先の<strong>駐車場へ専門スタッフが訪問</strong>し、シート・フロア・天井など車内を洗浄・消臭するサービスです。店舗に預けず、嘔吐・尿・灯油・タバコ臭など「自力では限界」の汚れを、温水吸引と専用洗剤で<strong>臭いの発生源から</strong>処理します。
    </p>
    <div class="mt-6 overflow-x-auto -mx-2 px-2">
      <table class="w-full min-w-[320px] text-xs sm:text-sm border-collapse">
        <thead>
          <tr class="bg-gray-50">
            <th class="border border-gray-200 px-2 py-2 text-left font-semibold">比較</th>
            <th class="border border-gray-200 px-2 py-2 text-center font-semibold">店舗持込</th>
            <th class="border border-gray-200 px-2 py-2 text-center font-semibold">ガソリンスタンド</th>
            <th class="border border-gray-200 px-2 py-2 text-center font-semibold text-primary">出張車内清掃</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="border border-gray-200 px-2 py-2 font-medium">訪問・駐車場完結</td>
            <td class="border border-gray-200 px-2 py-2 text-center">×</td>
            <td class="border border-gray-200 px-2 py-2 text-center">×</td>
            <td class="border border-gray-200 px-2 py-2 text-center font-bold text-primary">○</td>
          </tr>
          <tr>
            <td class="border border-gray-200 px-2 py-2 font-medium">嘔吐・尿の奥染み</td>
            <td class="border border-gray-200 px-2 py-2 text-center">△</td>
            <td class="border border-gray-200 px-2 py-2 text-center">×</td>
            <td class="border border-gray-200 px-2 py-2 text-center font-bold text-primary">○</td>
          </tr>
          <tr>
            <td class="border border-gray-200 px-2 py-2 font-medium">立会</td>
            <td class="border border-gray-200 px-2 py-2 text-center">要</td>
            <td class="border border-gray-200 px-2 py-2 text-center">要</td>
            <td class="border border-gray-200 px-2 py-2 text-center font-bold text-primary">不要可</td>
          </tr>
          <tr>
            <td class="border border-gray-200 px-2 py-2 font-medium">即日・24h受付</td>
            <td class="border border-gray-200 px-2 py-2 text-center">△</td>
            <td class="border border-gray-200 px-2 py-2 text-center">○</td>
            <td class="border border-gray-200 px-2 py-2 text-center font-bold text-primary">○</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="py-12 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-2xl sm:text-3xl font-bold text-center text-gray-900">こんなお悩みありませんか？</h2>
    <p class="mt-2 text-center text-sm text-gray-600">出張車内清掃 ご利用の方に多いお悩み</p>
    <div class="mt-6 grid gap-6 md:grid-cols-3">
      <figure class="bg-gray-50 rounded-xl overflow-hidden shadow-sm border border-gray-100">
        <Image src={worryDrink} alt="飲み物シミ" class="w-full h-56 object-cover" />
        <figcaption class="p-3 text-center text-sm font-semibold text-gray-800">飲み物シミ</figcaption>
      </figure>
      <figure class="bg-gray-50 rounded-xl overflow-hidden shadow-sm border border-gray-100">
        <Image src={worryCeiling} alt="天井ヤニヨゴレ" class="w-full h-56 object-cover" />
        <figcaption class="p-3 text-center text-sm font-semibold text-gray-800">天井ヤニヨゴレ</figcaption>
      </figure>
      <figure class="bg-gray-50 rounded-xl overflow-hidden shadow-sm border border-gray-100">
        <Image src={worrySeat} alt="嘔吐のシミ" class="w-full h-56 object-cover" />
        <figcaption class="p-3 text-center text-sm font-semibold text-gray-800">嘔吐のシミ</figcaption>
      </figure>
    </div>
  </div>
</section>

<section class="py-10 bg-amber-50/50 border-t border-b border-amber-100/50">
  <div class="max-w-4xl mx-auto px-6">
    <div class="bg-white text-gray-900 rounded-2xl p-5 sm:p-6 shadow-md border border-amber-200/40">
      <p class="text-sm sm:text-base font-semibold text-cta-red">{regionName} 地元密着 の出張</p>
      <p class="mt-3 text-base sm:text-lg leading-relaxed text-gray-800">
        「うわ、どうしよう…」その絶望、私たちがリセットします。お出かけ中の突然のトラブル。お子様やペットの車酔い、お酒の飲み過ぎによる
        <strong>車内 ゲロ 掃除</strong>。あるいは、うっかりこぼしてしまった灯油やオイルの鼻を突くニオイ……。
        「自分で拭いてみたけど、全然ニオイが取れない」「むしろ、拭けば拭くほど汚れが広がっていく気がする」そんな時、どうか一人で悩まないでください。
        私たちは、単なる「お掃除屋さん」ではありません。あなたの愛車に起きた「災難」をなかったことにし、心までスッキリさせる
        <strong>車内 クリーニング 専門 店</strong>です。
      </p>
      <p class="mt-3 text-sm text-cta-red font-semibold border-t border-gray-100 pt-3">
        ●家族以外の他人が、嘔吐等した場合、出張車内清掃に車両保険、個人賠償責任保険が使えます。
      </p>
    </div>
  </div>
</section>

<!-- Task 1: 「お悩み共感セクション」の新設 -->
<section class="py-12 bg-gray-100 border-b border-gray-200">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-2xl sm:text-3xl font-bold text-center text-gray-900 leading-tight">
      こんな「車内のニオイ・汚れ」のお悩みありませんか？
    </h2>
    
    <div class="mt-8 max-w-2xl mx-auto bg-white rounded-2xl p-6 sm:p-8 shadow-sm border border-gray-200/60">
      <ul class="space-y-4">
        <li class="flex items-start gap-3 text-base sm:text-lg font-medium text-gray-800">
          <span class="text-cta-red text-xl sm:text-2xl flex-shrink-0 mt-0.5">☑</span>
          <span>子供やペットが車酔いしてシートに吐いてしまった…</span>
        </li>
        <li class="flex items-start gap-3 text-base sm:text-lg font-medium text-gray-800">
          <span class="text-cta-red text-xl sm:text-2xl flex-shrink-0 mt-0.5">☑</span>
          <span>自分で拭き取っても、奥からモワッと悪臭が戻ってくる</span>
        </li>
        <li class="flex items-start gap-3 text-base sm:text-lg font-medium text-gray-800">
          <span class="text-cta-red text-xl sm:text-2xl flex-shrink-0 mt-0.5">☑</span>
          <span>おしっこや灯油をこぼしてしまい、運転するのもツラい…</span>
        </li>
        <li class="flex items-start gap-3 text-base sm:text-lg font-medium text-gray-800">
          <span class="text-cta-red text-xl sm:text-2xl flex-shrink-0 mt-0.5">☑</span>
          <span>どこに頼めばいいか分からないし、お店に車を持っていく時間もない！</span>
        </li>
      </ul>
    </div>
    
    <div class="mt-8 text-center bg-red-50 border border-red-100 rounded-2xl p-6 max-w-3xl mx-auto">
      <p class="text-base sm:text-lg font-bold text-cta-red leading-relaxed">
        そのまま放置すると悪化します！その絶望的な汚れとニオイ、<br />
        出張専門の「INS車内清掃」が<span class="underline decoration-2 decoration-amber-500 font-extrabold text-lg sm:text-xl">【ご自宅の駐車場】</span>でリセットします！
      </p>
    </div>
  </div>
