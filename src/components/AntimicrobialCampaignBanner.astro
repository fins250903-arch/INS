---
import { ANTIMICROBIAL_CAMPAIGN_LINE } from '../data/site';

const label = '抗菌コート';
---

<div
  class="mx-auto w-full max-w-xl sm:max-w-2xl overflow-hidden rounded-xl border-2 border-primary bg-white shadow-md"
  role="img"
  aria-label={`${label}。${ANTIMICROBIAL_CAMPAIGN_LINE}`}
>
  <div class="flex min-h-[4.5rem] items-stretch sm:min-h-[5rem]">
    <div class="flex w-14 shrink-0 flex-col items-center justify-center bg-primary px-2 py-3 sm:w-16">
      <svg class="h-8 w-8 text-white" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M12 3c-2.5 2.8-4 5.6-4 8.2 0 2.2 1.8 4 4 4s4-1.8 4-4c0-2.6-1.5-5.4-4-8.2Z"
          fill="currentColor"
          opacity="0.95"></path>
        <path d="M10 14v3a2 2 0 1 0 4 0v-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      </svg>
    </div>
    <div class="flex flex-1 flex-col justify-center gap-0.5 px-3 py-2 sm:px-4 sm:py-3">
      <p class="text-xs font-bold tracking-wide text-primary sm:text-sm">{label}</p>
      <p class="text-sm font-bold leading-snug text-cta-red sm:text-base">{ANTIMICROBIAL_CAMPAIGN_LINE}</p>
      <p class="text-[10px] text-gray-500 sm:text-xs">施工時オプション・お見積りにてご案内</p>
    </div>
  </div>
</div>
