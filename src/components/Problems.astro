---
const problems = [
  {
    title: "「昨夜の粗相、どうしよう…」",
    desc: "お子様やペットの車内 ゲロ 掃除。自分なりに拭いてみたけれど、どうしても「あのニオイ」が残ってしまう。"
  },
  {
    title: "「灯油やオイル、こぼしちゃった！」",
    desc: "鼻を突く強烈なニオイ。拭いても拭いても取れないし、車にダメージがいかないか不安。"
  },
  {
    title: "「中古車を買ったけど、前の人の生活臭が…」",
    desc: "せっかくの愛車なのに、独特のニオイのせいでリラックスできない。"
  },
  {
    title: "「友人に『なんかクサイ』と言われた…」",
    desc: "自分では気づきにくいヤニ・タバコ臭やペットのニオイ。大切な人を乗せた時のその一言、ショックですよね。"
  }
];
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4 inline-block border-b-4 border-primary pb-2">
        こういうご相談が一番多いんです
      </h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {problems.map(problem => (
        <div class="flex items-start bg-gray-50 p-6 rounded-2xl">
          <div class="bg-primary text-white w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 font-bold mr-4">
            ?
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-800 mb-2">{problem.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{problem.desc}</p>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-12 p-8 bg-primary/5 rounded-2xl border-2 border-dashed border-primary/30 text-center">
      <p class="text-xl font-bold text-gray-800">
        「もう、シートを交換するしかないの？」<br />
        <span class="text-primary text-2xl">…いえ、その前に一度、私たちの車 シート 洗浄を試させてください。</span>
      </p>
    </div>
  </div>
</section>
