---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import { canonicalUrl } from '../lib/canonical-url';
import { buildPageJsonLd } from '../lib/json-ld-site';

interface Props {
	title?: string;
	description?: string;
	/** 正規 URL（未指定時は現在パスから自動生成） */
	canonical?: string;
	/** head 内 JSON-LD（@graph 単一ドキュメント）。未指定時は WebPage の最小グラフ */
	jsonLd?: Record<string, unknown>;
	/** true のとき検索エンジンにインデックスさせない（thanks 等） */
	noindex?: boolean;
	/** meta keywords（ブログ seo.keywords 等） */
	keywords?: string;
	/** OGP / Twitter カード用の絶対 URL 画像 */
	ogImage?: string;
	ogType?: 'website' | 'article';
}

const {
	title = '大阪｜アイエヌエスINS出張車内清掃業者｜車内クリーニング',
	description = '「うわ、どうしよう…」その絶望、私たちがリセットします。お電話一本で、プロの【車内 洗浄】があなたのご自宅へ。',
	canonical,
	jsonLd,
	noindex = false,
	keywords,
	ogImage,
	ogType = 'website'
} = Astro.props;

const resolvedCanonical =
	canonical?.startsWith('http') ? canonical : canonicalUrl(canonical ?? Astro.url.pathname);
const resolvedJsonLd =
	jsonLd ??
	buildPageJsonLd({
		path: Astro.url.pathname,
		title,
		description
	});
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			canonical={resolvedCanonical}
			jsonLd={resolvedJsonLd}
			noindex={noindex}
			keywords={keywords}
			ogImage={ogImage}
			ogType={ogType}
		/>
	</head>
	<body class="bg-white">
		<slot />
	</body>
</html>
